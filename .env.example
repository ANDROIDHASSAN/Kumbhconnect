# ─────────────────────────────────────────────────────────────
# Kumbh Connect — environment variables
# Copy to .env.local and fill in. The app RUNS WITHOUT ANY of these
# (mock data + click-to-chat fallback). Add keys to unlock real features.
# ─────────────────────────────────────────────────────────────

# WhatsApp click-to-chat (Phase 0). Number in international format, no +, no spaces.
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Public site URL (used for SEO canonical / sitemap / OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Phase 1). If unset, the app falls back to in-memory mock data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (Phase 1 test / Phase 2 live). If unset, payment step is stubbed.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google Maps Platform (Phase 2). If unset, static map placeholders are shown.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# WhatsApp Cloud API provider (Phase 3). If unset, click-to-chat fallback is used.
WHATSAPP_PROVIDER=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Analytics (Phase 3, loaded only after consent)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Cloudinary image uploads (Phase 3). If unset, admins paste an image URL instead.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin access (simple gate for Phase 0/1). Change before deploy.
ADMIN_PASSWORD=kumbh2027
