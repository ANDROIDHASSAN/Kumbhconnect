# ─────────────────────────────────────────────────────────────
# Kumbh Connect — server environment
# Copy to .env. The server RUNS WITHOUT a database (JSON file fallback),
# but set DATABASE_URL to use real Postgres (the "P" in PERN).
# ─────────────────────────────────────────────────────────────

PORT=4000

# Postgres. With docker-compose (provided) this is ready to use:
DATABASE_URL=postgres://kumbh:kumbh@localhost:5432/kumbh_connect

# Allow the React client origin (Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# Admin gate (the client logs in and receives a bearer token)
ADMIN_PASSWORD=kumbh2027

# Razorpay (optional — stubbed to a UPI deep link without these)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# WhatsApp Cloud API (optional — click-to-chat fallback otherwise)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Cloudinary image uploads (optional — paste-a-URL fallback otherwise).
# From your Cloudinary dashboard → Account Details.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
